// ===================== المنتجات =====================
function renderProducts() {
    const q = (document.getElementById('productSearch').value||'').toLowerCase();
    const cat = document.getElementById('productCatFilter').value;
    const cf = document.getElementById('productCatFilter');
    cf.innerHTML = '<option value="">كل الفئات</option>' + db.categories.map(c=>`<option value="${c.id}"${c.id===cat?' selected':''}>${c.name}</option>`).join('');
    let prods = db.products;
    if (q) prods = prods.filter(p=>p.name.toLowerCase().includes(q)||(p.barcode||'').includes(q));
    if (cat) prods = prods.filter(p=>p.categoryId===cat);
    const minStock = db.settings.minStock || 5;
    document.getElementById('productsTable').innerHTML = `
        <thead><tr><th>الباركود</th><th>الاسم</th><th>الفئة</th><th>المخزون</th><th>حد الأمان</th><th>التكلفة</th><th>سعر البيع</th><th>الحالة</th><th>إجراءات</th></tr></thead>
        <tbody>${prods.length ? prods.map(p=>{
            const lowQ = p.qty <= (p.minStock||minStock);
