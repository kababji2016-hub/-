    document.getElementById('modalBody').innerHTML = `
        <div class="form-grid form-grid-2">
            <div class="form-group"><label>اسم المادة / الكتاب *</label><input type="text" class="form-control" id="pmName" value="${p?p.name:''}"></div>
            <div class="form-group"><label>الباركود / ISBN</label><input type="text" class="form-control" id="pmBarcode" value="${p?p.barcode||'':''}"></div>
            <div class="form-group"><label>الفئة</label>
                <select class="form-control" id="pmCat">
                    <option value="">-- بدون تصنيف --</option>
                    ${db.categories.map(c=>`<option value="${c.id}"${p&&p.categoryId===c.id?' selected':''}>${c.name}</option>`).join('')}
                </select>
            </div>
            <div class="form-group"><label>المؤلف / جهة النشر</label><input type="text" class="form-control" id="pmAuthor" value="${p?p.author||'':''}"></div>
            <div class="form-group"><label>الكمية الافتتاحية</label><input type="number" class="form-control" id="pmQty" value="${p?p.qty:0}" min="0"></div>
            <div class="form-group"><label>حد الأمان الأدنى</label><input type="number" class="form-control" id="pmMin" value="${p?p.minStock||5:5}" min="0"></div>
            <div class="form-group"><label>سعر التكلفة (ريال)</label><input type="number" class="form-control" id="pmCost" value="${p?p.cost||0:0}" step="0.01"></div>
            <div class="form-group"><label>سعر البيع (ريال)</label><input type="number" class="form-control" id="pmPrice" value="${p?p.price||0:0}" step="0.01"></div>
            <div class="form-group" style="grid-column:span 2"><label>الوصف والملاحظات</label><input type="text" class="form-control" id="pmDesc" value="${p?p.desc||'':''}"></div>
        </div>
    `;
    document.getElementById('modalFooter').innerHTML = `
        <button class="btn btn-outline" onclick="closeModalNow()">إلغاء</button>
        <button class="btn btn-primary" onclick="saveProduct('${id||''}', ${fromPurch})">💾 حفظ الصنف</button>
    `;
    document.getElementById('modalOverlay').style.display = 'flex';
}

function saveProduct(id, fromPurch) {
    const name = document.getElementById('pmName').value.trim();
    if (!name) return alert('يجب تسمية الصنف');
    const prod = {
        id: id || genId('PRD'), name,
        barcode: document.getElementById('pmBarcode').value.trim(),
        categoryId: document.getElementById('pmCat').value,
        author: document.getElementById('pmAuthor').value.trim(),
        qty: parseInt(document.getElementById('pmQty').value)||0,
        minStock: parseInt(document.getElementById('pmMin').value)||5,
        cost: parseFloat(document.getElementById('pmCost').value)||0,
        price: parseFloat(document.getElementById('pmPrice').value)||0,
        desc: document.getElementById('pmDesc').value.trim()
    };
    if (id) { const idx=db.products.findIndex(x=>x.id===id); if(idx>=0) db.products[idx]=prod; }
    else db.products.push(prod);
    saveDB(); closeModalNow();
    if (fromPurch) initPurchForm(); else renderProducts();
}

function deleteProduct(id) {
    if (!confirm('هل تود حذف هذه السلعة؟')) return;
    db.products = db.products.filter(x=>x.id!==id); saveDB(); renderProducts();
}

// ===================== الفئات =====================
function renderCategories() {
    document.getElementById('catsTableBody').innerHTML = db.categories.map((c,i)=>`
        <tr>
            <td>${i+1}</td>
            <td><b>${c.name}</b></td>
            <td><span class="badge badge-info">${db.products.filter(p=>p.categoryId===c.id).length} صنف</span></td>
            <td>
                <button class="btn btn-outline btn-sm" onclick="openCatModal('${c.id}')">✏️ تعديل</button>
                <button class="btn btn-danger btn-sm" onclick="deleteCat('${c.id}')">🗑️ حذف</button>
            </td>
        </tr>
    `).join('');
}

function openCatModal(id) {
    const c = id ? db.categories.find(x=>x.id===id) : null;
    document.getElementById('modalTitle').textContent = c ? 'تعديل الفئة' : 'إضافة فئة جديدة';
    document.getElementById('modalBody').innerHTML = `<div class="form-group"><label>اسم الفئة *</label><input type="text" class="form-control" id="catName" value="${c?c.name:''}"></div>`;
    document.getElementById('modalFooter').innerHTML = `<button class="btn btn-outline" onclick="closeModalNow()">إلغاء</button><button class="btn btn-primary" onclick="saveCat('${id||''}')">💾 حفظ</button>`;
    document.getElementById('modalOverlay').style.display = 'flex';
}

function saveCat(id) {
    const name = document.getElementById('catName').value.trim();
    if (!name) return alert('الرجاء كتابة اسم الفئة');
    if (id) { const c=db.categories.find(x=>x.id===id); if(c) c.name=name; }
    else db.categories.push({ id: genId('CAT'), name });
    saveDB(); closeModalNow(); renderCategories();
}

function deleteCat(id) {
    if (!confirm('حذف الفئة لا يحذف السلع المرتبطة بها، هل تريد الاستمرار؟')) return;
    db.categories = db.categories.filter(x=>x.id!==id); saveDB(); renderCategories();
}

// ===================== العملاء والموردون =====================
function renderCustomers() {
    const q = (document.getElementById('custSearch').value||'').toLowerCase();
    const custs = db.customers.filter(c=>c.name.toLowerCase().includes(q)||(c.phone||'').includes(q));
    document.getElementById('customersTable').innerHTML = `
        <thead><tr><th>اسم العميل</th><th>رقم الجوال</th><th>العنوان</th><th>إجمالي مشترياته</th><th>عمليات</th></tr></thead>
        <tbody>${custs.map(c=>{
            const totalSales = db.invoices.filter(i=>i.type==='sale'&&i.customerId===c.id).reduce((s,i)=>s+(i.netTotal||0),0);
            return `<tr><td><b>${c.name}</b></td><td>${c.phone||'-'}</td><td>${c.address||'-'}</td><td style="font-weight:700;color:var(--success)">${fmt(totalSales)} ر.س</td>
            <td>
                <button class="btn btn-outline btn-sm" onclick="openPersonModal('customer','${c.id}')">✏️ تعديل</button>
                ${c.id!=='cust0'?`<button class="btn btn-danger btn-sm" onclick="deletePerson('customer','${c.id}')">🗑️</button>`:''}
            </td></tr>`;
        }).join('')}</tbody>
    `;
}

function renderSuppliers() {
    const q = (document.getElementById('suppSearch').value||'').toLowerCase();
    const supps = db.suppliers.filter(s=>s.name.toLowerCase().includes(q)||(s.phone||'').includes(q));
    document.getElementById('suppliersTable').innerHTML = `
        <thead><tr><th>اسم المورد</th><th>رقم الجوال</th><th>العنوان</th><th>إجمالي التوريدات</th><th>عمليات</th></tr></thead>
        <tbody>${supps.length ? supps.map(s=>{
            const totalPurch = db.invoices.filter(i=>i.type==='purchase'&&i.supplierId===s.id).reduce((sum,i)=>sum+(i.netTotal||0),0);
            return `<tr><td><b>${s.name}</b></td><td>${s.phone||'-'}</td><td>${s.address||'-'}</td><td style="font-weight:700;color:var(--info)">${fmt(totalPurch)} ر.س</td>
            <td>
                <button class="btn btn-outline btn-sm" onclick="openPersonModal('supplier','${s.id}')">✏️ تعديل</button>
                <button class="btn btn-danger btn-sm" onclick="deletePerson('supplier','${s.id}')">🗑️</button>
            </td></tr>`;
        }).join('') : '<tr><td colspan="5" class="empty-state">لا يوجد موردون</td></tr>'}</tbody>
    `;
}

function openPersonModal(type, id) {
    const arr = type==='customer' ? db.customers : db.suppliers;
    const item = id ? arr.find(x=>x.id===id) : null;
    const lbl = type==='customer' ? 'العميل' : 'المورد';
    document.getElementById('modalTitle').textContent = (item?'تعديل بيانات ':'إضافة ') + lbl;
    document.getElementById('modalBody').innerHTML = `
        <div class="form-grid">
            <div class="form-group"><label>الاسم الكامل *</label><input type="text" class="form-control" id="perName" value="${item?item.name:''}"></div>
            <div class="form-group"><label>رقم الهاتف</label><input type="text" class="form-control" id="perPhone" value="${item?item.phone||'':''}"></div>
            <div class="form-group"><label>العنوان</label><input type="text" class="form-control" id="perAddress" value="${item?item.address||'':''}"></div>
        </div>
    `;
    document.getElementById('modalFooter').innerHTML = `
        <button class="btn btn-outline" onclick="closeModalNow()">إغلاق</button>
        <button class="btn btn-primary" onclick="savePerson('${type}','${id||''}')">💾 حفظ</button>
    `;
    document.getElementById('modalOverlay').style.display = 'flex';
}

function savePerson(type, id) {
    const name = document.getElementById('perName').value.trim();
    if (!name) return alert('الاسم حقل إلزامي');
    const arr = type==='customer' ? db.customers : db.suppliers;
    const data = {
        id: id || genId(type==='customer'?'CST':'SPL'), name,
        phone: document.getElementById('perPhone').value.trim(),
        address: document.getElementById('perAddress').value.trim()
    };
    if (id) { const idx=arr.findIndex(x=>x.id===id); if(idx>=0) arr[idx]=data; }
    else arr.push(data);
    saveDB(); closeModalNow();
    type==='customer' ? renderCustomers() : renderSuppliers();
}

function deletePerson(type, id) {
    if (!confirm('هل تود حذف هذا الطرف؟')) return;
    if (type==='customer') { db.customers=db.customers.filter(x=>x.id!==id); renderCustomers(); }
    else { db.suppliers=db.suppliers.filter(x=>x.id!==id); renderSuppliers(); }
    saveDB();
}

// ===================== المصروفات =====================
function fillExpCatSelect() {
    const sel = document.getElementById('expCat');
    if (sel) sel.innerHTML = db.expenseCategories.map(c=>`<option>${c}</option>`).join('');
}

function addExpense() {
    const desc = document.getElementById('expDesc').value.trim();
    const amount = parseFloat(document.getElementById('expAmount').value)||0;
    const category = document.getElementById('expCat').value;
    const date = document.getElementById('expDate').value;
    if (!desc || amount <= 0 || !date) return alert('يرجى استيفاء جميع الحقول والمبلغ أكبر من صفر');
    db.expenses.push({ id: genId('EXP'), desc, amount, category, date });
    saveDB();
    document.getElementById('expDesc').value = '';
    document.getElementById('expAmount').value = '';
    renderExpenses();
}

function openExpCatModal() {
    document.getElementById('modalTitle').textContent = '⚙️ إدارة فئات المصروفات';
    document.getElementById('modalBody').innerHTML = `
        <div style="margin-bottom:16px">
            <div style="font-weight:700;font-size:13px;margin-bottom:8px;color:var(--primary)">إضافة فئة جديدة:</div>
            <div style="display:flex;gap:8px">
                <input type="text" class="form-control" id="newExpCatName" placeholder="اسم الفئة الجديدة...">
                <button class="btn btn-primary btn-sm" onclick="addExpCat()">+ إضافة</button>
            </div>
        </div>
        <div style="font-weight:700;font-size:13px;margin-bottom:8px;color:var(--text2)">الفئات الحالية:</div>
        <div id="expCatsList"></div>
    `;
    document.getElementById('modalFooter').innerHTML = `<button class="btn btn-outline" onclick="closeModalNow();renderExpenses()">إغلاق</button>`;
    renderExpCatsList();
    document.getElementById('modalOverlay').style.display = 'flex';
}

function renderExpCatsList() {
    const el = document.getElementById('expCatsList');
    if (!el) return;
    el.innerHTML = db.expenseCategories.map((c,i)=>`
        <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 12px;border:1px solid var(--border);border-radius:6px;margin-bottom:6px">
            <span>📌 ${c}</span>
            <button class="btn btn-danger btn-sm" onclick="deleteExpCat(${i})">🗑️ حذف</button>
        </div>
    `).join('');
}

function addExpCat() {
    const name = document.getElementById('newExpCatName').value.trim();
    if (!name) return alert('أدخل اسم الفئة');
    if (db.expenseCategories.includes(name)) return alert('هذه الفئة موجودة مسبقاً');
    db.expenseCategories.push(name);
    saveDB();
    document.getElementById('newExpCatName').value = '';
    renderExpCatsList();
    fillExpCatSelect();
}

function deleteExpCat(idx) {
    if (!confirm('هل تود حذف هذه الفئة؟')) return;
    db.expenseCategories.splice(idx, 1);
    saveDB();
    renderExpCatsList();
    fillExpCatSelect();
}

function renderExpenses() {
    document.getElementById('expDate').value = getTodayDate();
    fillExpCatSelect();
    const filterMonth = document.getElementById('expFilter').value || getTodayDate().slice(0,7);
    document.getElementById('expFilter').value = filterMonth;
    const list = db.expenses.filter(e=>e.date.startsWith(filterMonth));
    const sumEx = list.reduce((s,e)=>s+e.amount, 0);
    document.getElementById('expensesTable').innerHTML = `
        <thead><tr><th>التاريخ</th><th>البيان</th><th>الفئة</th><th>المبلغ</th><th>إجراءات</th></tr></thead>
        <tbody>${list.length ? list.map(e=>`
            <tr>
                <td>${e.date}</td>
                <td><b>${e.desc}</b></td>
                <td><span class="badge badge-warning">${e.category}</span></td>
                <td style="font-weight:700;color:var(--danger)">${fmt(e.amount)} ر.س</td>
                <td><button class="btn btn-danger btn-sm" onclick="deleteExpense('${e.id}')">🗑️ شطب</button></td>
            </tr>
        `).join('') : '<tr><td colspan="5" class="empty-state">لم يتم تدوين قيود هذا الشهر</td></tr>'}
        <tr style="background:#f1f3f5;font-weight:bold"><td colspan="3">مجموع النفقات الكلي للشهر</td><td style="color:var(--danger);font-size:14px">${fmt(sumEx)} ر.س</td><td></td></tr>
        </tbody>
    `;
}

function deleteExpense(id) {
    if (!confirm('هل تريد شطب قيد هذا المصروف؟')) return;
    db.expenses = db.expenses.filter(e=>e.id!==id); saveDB(); renderExpenses();
}

// ===================== الإعدادات والمستخدمون =====================
function renderSettings() {
    document.getElementById('setStoreName').value = db.settings.storeName || '';
    document.getElementById('setPhone').value = db.settings.phone || '';
    document.getElementById('setAddress').value = db.settings.address || '';
    document.getElementById('setVatNum').value = db.settings.vatNum || '';
    document.getElementById('setMinStock').value = db.settings.minStock || 5;
    document.getElementById('setVatPct').value = db.settings.vatPct || 15;

    document.getElementById('usersList').innerHTML = db.users.map(u=>`
        <div style="display:flex;justify-content:space-between;align-items:center;padding:10px;border:1px solid var(--border);border-radius:8px;margin-bottom:8px">
            <div>
                <span>👤 <b>${u.username}</b></span>
                <div style="font-size:11px;color:var(--text3);margin-top:4px">الصلاحيات: ${(u.permissions||[]).map(p=>{const perm=ALL_PERMISSIONS.find(x=>x.key===p);return perm?perm.label:p;}).join(' • ')}</div>
            </div>
            <div style="display:flex;gap:6px;align-items:center">
                <button class="btn btn-outline btn-sm" onclick="openEditUserModal('${u.username}')">✏️ تعديل</button>
                ${u.username !== currentUser.username ? `<button class="btn btn-danger btn-sm" onclick="deleteUser('${u.username}')">🗑️ حذف</button>` : '<small style="color:var(--text3)">حسابك الحالي</small>'}
            </div>
        </div>
    `).join('');

    // رسم مربعات الصلاحيات للمستخدم الجديد
    renderPermGrid('permGrid', []);
}

function renderPermGrid(containerId, selected) {
    document.getElementById(containerId).innerHTML = ALL_PERMISSIONS.map(p=>`
        <label class="perm-item ${selected.includes(p.key)?'checked':''}">
            <input type="checkbox" value="${p.key}" ${selected.includes(p.key)?'checked':''} onchange="this.closest('.perm-item').classList.toggle('checked',this.checked)">
            ${p.label}
        </label>
    `).join('');
}

function getSelectedPerms(containerId) {
    return [...document.querySelectorAll(`#${containerId} input[type=checkbox]:checked`)].map(x=>x.value);
}

function openEditUserModal(username) {
    const u = db.users.find(x=>x.username===username);
    if (!u) return;
    document.getElementById('modalTitle').textContent = 'تعديل المستخدم: ' + username;
    document.getElementById('modalBody').innerHTML = `
        <div class="form-grid" style="margin-bottom:16px">
            <div class="form-group"><label>اسم المستخدم الجديد</label><input type="text" class="form-control" id="editUsername" value="${u.username}"></div>
            <div class="form-group"><label>كلمة المرور الجديدة</label>
                <div class="pass-wrap">
                    <input type="password" class="form-control" id="editPassword" value="${u.password}" style="padding-left:44px">
                    <span class="pass-toggle" onclick="togglePassVisibility('editPassword', this)">👁️</span>
                </div>
            </div>
        </div>
        <div style="font-weight:700;font-size:12px;margin-bottom:8px;color:var(--text2)">الصلاحيات:</div>
        <div class="perm-grid" id="editPermGrid"></div>
    `;
    document.getElementById('modalFooter').innerHTML = `
        <button class="btn btn-outline" onclick="closeModalNow()">إلغاء</button>
        <button class="btn btn-primary" onclick="saveEditUser('${username}')">💾 حفظ التعديلات</button>
    `;
    renderPermGrid('editPermGrid', u.permissions || []);
    document.getElementById('modalOverlay').style.display = 'flex';
}

function saveEditUser(oldUsername) {
    const newUsername = document.getElementById('editUsername').value.trim();
    const newPassword = document.getElementById('editPassword').value;
    const perms = getSelectedPerms('editPermGrid');
    if (!newUsername || !newPassword) return alert('يرجى تعبئة اسم المستخدم وكلمة المرور');
    if (newUsername !== oldUsername && db.users.some(x=>x.username===newUsername)) return alert('اسم المستخدم مستخدم مسبقاً');
    const u = db.users.find(x=>x.username===oldUsername);
    if (u) { u.username = newUsername; u.password = newPassword; u.permissions = perms; }
    // تحديث المستخدم الحالي إن كان هو نفسه
    if (currentUser.username === oldUsername) {
        currentUser.username = newUsername;
        currentUser.password = newPassword;
        currentUser.permissions = perms;
        document.getElementById('topbarUser').textContent = '👤 ' + newUsername;
    }
    saveDB(); closeModalNow(); renderSettings();
    alert('✅ تم تحديث بيانات المستخدم بنجاح');
}

function saveSettings() {
    db.settings = {
        storeName: document.getElementById('setStoreName').value.trim(),
        phone: document.getElementById('setPhone').value.trim(),
        address: document.getElementById('setAddress').value.trim(),
        vatNum: document.getElementById('setVatNum').value.trim(),
        minStock: parseInt(document.getElementById('setMinStock').value)||5,
        vatPct: parseFloat(document.getElementById('setVatPct').value)||0
    };
    document.getElementById('storeName').textContent = db.settings.storeName;
    saveDB();
    alert('✅ تم حفظ الإعدادات بنجاح');
}

function saveUser() {
    const u = document.getElementById('newUsername').value.trim();
    const p = document.getElementById('newPassword').value;
    const perms = getSelectedPerms('permGrid');
    if (!u || !p) return alert('يرجى تعبئة اسم الحساب وكلمة المرور');
    if (db.users.some(x=>x.username===u)) return alert('اسم المستخدم مسجل مسبقاً');
    db.users.push({ username: u, password: p, permissions: perms });
    saveDB();
    document.getElementById('newUsername').value = '';
    document.getElementById('newPassword').value = '';
    renderSettings();
    alert('✅ تم إنشاء المستخدم الجديد بنجاح');
}

function deleteUser(username) {
    if (!confirm(`هل تود حذف المستخدم [${username}]؟`)) return;
    db.users = db.users.filter(x=>x.username!==username); saveDB(); renderSettings();
}

// ===================== النسخ الاحتياطي =====================
function backupData() {
    try {
        const rawStr = btoa(unescape(encodeURIComponent(JSON.stringify(db))));
        const dataUri = 'data:application/json;charset=utf-8;base64,' + rawStr;
        const exportName = 'نسخة_احتياطية_' + new Date().toISOString().split('T')[0] + '.json';
        const a = document.createElement('a');
        a.setAttribute('href', dataUri);
        a.setAttribute('download', exportName);
        a.click();
    } catch(e) { alert('تعذر إنشاء ملف التصدير: ' + e.message); }
}

function importBackup() {
    if (confirm('تحذير: استعادة نسخة احتياطية سيحل محل البيانات الحالية بالكامل، هل تريد المتابعة؟')) {
        document.getElementById('importFile').click();
    }
}

function doImport(e) {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = function(evt) {
        try {
            let rawData = evt.target.result;
            if (!rawData.trim().startsWith('{')) rawData = decodeURIComponent(escape(atob(rawData.trim())));
            const parsed = JSON.parse(rawData);
            if (parsed.settings && parsed.users) {
                db = parsed;
                saveDB();
                alert('✅ تم استعادة قاعدة البيانات بنجاح، سيتم إعادة التحميل.');
                location.reload();
            } else alert('فشل الاستيراد: هيكلية الملف غير متطابقة');
        } catch(err) { alert('تعذر قراءة الملف: ' + err.message); }
    };
    reader.readAsText(file);
}

// ===================== MODAL =====================
function closeModal(e) { if(e.target.id==='modalOverlay') closeModalNow(); }
function closeModalNow() { document.getElementById('modalOverlay').style.display = 'none'; }

// ===================== تهيئة التطبيق =====================
function initApp() {
    loadDB();
    buildSidebar();
    document.getElementById('storeName').textContent = db.settings.storeName;
    // الصفحة الأولى حسب الصلاحيات
    const firstPage = ALL_PERMISSIONS.find(p => hasPermission(p.key));
    if (firstPage) showPage(firstPage.key);
}

window.onload = () => { loadDB(); };
</script>
