        /* LAYOUT */
        #app { display:none; min-height:100vh; }
        .sidebar { position:fixed; top:0; right:0; width:var(--sidebar-w); height:100vh; background:var(--primary); color:white; display:flex; flex-direction:column; z-index:100; overflow-y:auto; }
