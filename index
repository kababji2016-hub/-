            return `<tr class="${p.qty===0||lowQ?'low-stock-row':''}">
                <td style="font-family:monospace;color:var(--text3)">${p.barcode||'-'}</td>
                <td><b>${p.name}</b><br><small style="color:var(--text3)">${p.author||''}</small></td>
                <td>${cInfo?cInfo.name:'-'}</td>
                <td style="font-weight:800;color:${p.qty===0?'var(--danger)':lowQ?'var(--warning)':'var(--success)'}">${p.qty} وحدة</td>
                <td>${p.minStock||minStock}</td>
                <td>${fmt(p.cost)} ر.س</td>
                <td style="font-weight:700;color:var(--primary)">${fmt(p.price)} ر.س</td>
                <td>${p.qty===0?'<span class="badge badge-danger">نفد</span>':lowQ?'<span class="badge badge-warning">منخفض</span>':'<span class="badge badge-success">متوفر</span>'}</td>
                <td style="display:flex;gap:4px">
                    <button class="btn btn-outline btn-sm" onclick="openProductModal('${p.id}')">✏️ تعديل</button>
                    <button class="btn btn-danger btn-sm" onclick="deleteProduct('${p.id}')">🗑️</button>
                </td>
            </tr>`;
        }).join('') : '<tr><td colspan="9" class="empty-state">لا توجد سلع مدرجة</td></tr>'}</tbody>
    `;
}

function openProductModal(id, fromPurch=false) {
