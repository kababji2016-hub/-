        .form-control:focus { outline:none; border-color:var(--primary-light); box-shadow:0 0 0 3px rgba(37,99,168,0.1); }

        /* الأزرار */
        .btn { padding:9px 18px; border-radius:7px; font-size:13px; font-weight:700; cursor:pointer; border:none; font-family:inherit; transition:all 0.2s; display:inline-flex; align-items:center; gap:6px; }
        .btn-primary { background:var(--primary); color:white; }
        .btn-primary:hover { background:var(--primary-light); }
        .btn-success { background:var(--success); color:white; }
