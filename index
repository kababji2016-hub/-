<script>
// ===================== قاعدة البيانات =====================
const DB_KEY = 'libsys_v3';
let db = {};

// تعريف الصلاحيات المتاحة
const ALL_PERMISSIONS = [
    { key: 'dashboard', label: '🏠 لوحة التحكم' },
    { key: 'sale', label: '🧾 فاتورة مبيعات' },
    { key: 'purchase', label: '📦 فاتورة مشتريات' },
    { key: 'invoices', label: '📋 سجل الفواتير' },
    { key: 'products', label: '📗 الأصناف والكتب' },
    { key: 'categories', label: '🗂️ الفئات' },
    { key: 'customers', label: '👥 إدارة العملاء' },
    { key: 'suppliers', label: '🏭 إدارة الموردين' },
    { key: 'expenses', label: '💸 المصروفات' },
    { key: 'settings', label: '⚙️ الإعدادات' },
];

function loadDB() {
    try {
        const raw = localStorage.getItem(DB_KEY);
        if (raw) db = JSON.parse(atob(raw));
    } catch(e) { console.error('خطأ في قراءة قاعدة البيانات', e); }

    if (!db.settings) db.settings = { storeName: '', phone: '', address: '', vatNum: '', minStock: 5, vatPct: 15 };
    if (!db.users) db.users = [{
        username: 'admin',
        password: '1234',
        permissions: ALL_PERMISSIONS.map(p => p.key)
    }];
    // ترقية المستخدمين القدامى: إضافة permissions إن لم تكن موجودة
    db.users = db.users.map(u => {
        if (!u.permissions) {
            u.permissions = u.role === 'admin' ? ALL_PERMISSIONS.map(p => p.key) : ['dashboard', 'sale'];
        }
        return u;
    });
    if (!db.categories) db.categories = [
        { id: 'cat1', name: 'كتب علمية وروايات' },
        { id: 'cat2', name: 'قرطاسية وأدوات مكتبية' }
    ];
    if (!db.expenseCategories) db.expenseCategories = [
        'إيجار ومستودعات',
        'كهرباء ومياه ومرافق',
        'رواتب وأجور',
        'صيانة وتشغيل',
        'تسويق وإعلانات',
        'أخرى متنوعة'
    ];
    if (!db.products) db.products = [];
    if (!db.customers) db.customers = [{ id: 'cust0', name: 'عميل نقدي عام', phone: '', address: '' }];
    if (!db.suppliers) db.suppliers = [];
    if (!db.invoices) db.invoices = [];
    if (!db.expenses) db.expenses = [];
    saveDB();
}

function saveDB() {
    try {
        localStorage.setItem(DB_KEY, btoa(unescape(encodeURIComponent(JSON.stringify(db)))));
    } catch(e) {
        alert('فشل حفظ البيانات: ' + e.message);
    }
}

function genId(prefix) {
    return prefix + '_' + Date.now() + '_' + Math.random().toString(36).substr(2,4);
}

// ===================== تسجيل الدخول =====================
let currentUser = null;

function togglePassVisibility(inputId, btn) {
    const input = document.getElementById(inputId);
    if (input.type === 'password') {
        input.type = 'text';
        btn.textContent = '🙈';
    } else {
        input.type = 'password';
        btn.textContent = '👁️';
    }
}

function doLogin() {
    const u = document.getElementById('loginUser').value.trim();
    const p = document.getElementById('loginPass').value;
    const user = db.users.find(x => x.username === u && x.password === p);
    if (user) {
        currentUser = user;
        document.getElementById('loginScreen').style.display = 'none';
        document.getElementById('app').style.display = 'flex';
        document.getElementById('topbarUser').textContent = '👤 ' + user.username;
        document.getElementById('loginErr').style.display = 'none';
        initApp();
    } else {
        document.getElementById('loginErr').style.display = 'block';
    }
}

function doLogout() {
    currentUser = null;
    document.getElementById('loginScreen').style.display = 'flex';
    document.getElementById('app').style.display = 'none';
    document.getElementById('loginPass').value = '';
    document.getElementById('loginUser').value = '';
}

function hasPermission(page) {
    if (!currentUser) return false;
    return currentUser.permissions && currentUser.permissions.includes(page);
}

// ===================== التوجيه والصلاحيات =====================
const pageTitles = {
    dashboard: 'لوحة التحكم',
    sale: 'إنشاء فاتورة مبيعات',
    purchase: 'فاتورة مشتريات',
    invoices: 'سجل الفواتير',
    products: 'دليل الأصناف والكتب',
    categories: 'التصنيفات',
    customers: 'إدارة العملاء',
    suppliers: 'إدارة الموردين',
    expenses: 'المصروفات',
    settings: 'الإعدادات'
};

const navItems = [
    { section: 'الرئيسية' },
    { page: 'dashboard', icon: '🏠', label: 'لوحة التحكم' },
    { section: 'المعاملات' },
    { page: 'sale', icon: '🧾', label: 'فاتورة المبيعات' },
    { page: 'purchase', icon: '📦', label: 'فاتورة المشتريات' },
    { page: 'invoices', icon: '📋', label: 'سجل الفواتير' },
    { section: 'المخزون' },
    { page: 'products', icon: '📗', label: 'الأصناف والكتب' },
    { page: 'categories', icon: '🗂️', label: 'الفئات' },
    { section: 'الأطراف' },
    { page: 'customers', icon: '👥', label: 'إدارة العملاء' },
    { page: 'suppliers', icon: '🏭', label: 'إدارة الموردين' },
    { section: 'المالية' },
    { page: 'expenses', icon: '💸', label: 'المصروفات' },
    { section: 'النظام' },
    { page: 'settings', icon: '⚙️', label: 'الإعدادات' },
    { special: 'backup' },
    { special: 'import' },
];

function buildSidebar() {
    const nav = document.getElementById('sidebarNav');
    nav.innerHTML = navItems.map(item => {
        if (item.section) return `<div class="nav-section">${item.section}</div>`;
        if (item.page) {
            if (!hasPermission(item.page)) return '';
            return `<div class="nav-item" onclick="showPage('${item.page}')"><span class="icon">${item.icon}</span>${item.label}</div>`;
        }
        if (item.special === 'backup') return `<div class="nav-item" onclick="backupData()"><span class="icon">💾</span>نسخة احتياطية</div>`;
        if (item.special === 'import') return `<div class="nav-item" onclick="importBackup()"><span class="icon">📥</span>استعادة البيانات</div>`;
        return '';
    }).join('');
}

function showPage(name) {
    if (!hasPermission(name)) return alert('ليس لديك صلاحية للوصول إلى هذه الصفحة');
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    const tp = document.getElementById('page-' + name);
    if (tp) tp.classList.add('active');
    document.querySelectorAll('.nav-item').forEach(n => {
        if (n.getAttribute('onclick') && n.getAttribute('onclick').includes("'" + name + "'")) n.classList.add('active');
    });
    document.getElementById('pageTitle').textContent = pageTitles[name] || name;
    if (name === 'dashboard') renderDashboard();
    if (name === 'products') renderProducts();
    if (name === 'invoices') renderInvoices();
    if (name === 'customers') renderCustomers();
    if (name === 'suppliers') renderSuppliers();
    if (name === 'expenses') renderExpenses();
    if (name === 'categories') renderCategories();
    if (name === 'settings') renderSettings();
    if (name === 'sale') initSaleForm();
    if (name === 'purchase') initPurchForm();
}

// ===================== لوحة التحكم =====================
function renderDashboard() {
    const today = new Date().toISOString().split('T')[0];
    const thisMonth = today.slice(0,7);
    const sales = db.invoices.filter(i => i.type === 'sale');
    const todaySales = sales.filter(i => i.date === today);
    const monthSales = sales.filter(i => i.date.startsWith(thisMonth));
    const totalRevenue = monthSales.reduce((s,i) => s + (i.netTotal||0), 0);
    const totalProfit = monthSales.reduce((s,i) => s + ((i.netTotal||0) - (i.costTotal||0)), 0);
    const lowStock = db.products.filter(p => p.qty <= (p.minStock || db.settings.minStock));

    document.getElementById('dashStats').innerHTML = `
        <div class="stat-card"><div class="stat-icon">💰</div><div class="stat-label">مبيعات الشهر الحالي</div><div class="stat-value">${fmt(totalRevenue)}</div><div class="stat-sub">ريال سعودي صافي</div></div>
        <div class="stat-card"><div class="stat-icon">📈</div><div class="stat-label">العوائد الربحية (تقريبي)</div><div class="stat-value" style="color:var(--success)">${fmt(totalProfit)}</div><div class="stat-sub">بناءً على فروقات التكلفة</div></div>
        <div class="stat-card"><div class="stat-icon">🧾</div><div class="stat-label">مبيعات اليوم</div><div class="stat-value">${fmt(todaySales.reduce((s,i)=>s+(i.netTotal||0),0))}</div><div class="stat-sub">${todaySales.length} عملية</div></div>
        <div class="stat-card"><div class="stat-icon">⚠️</div><div class="stat-label">أصناف تحت حد الطلب</div><div class="stat-value" style="color:var(--danger)">${lowStock.length}</div><div class="stat-sub">تتطلب إعادة توريد</div></div>
    `;

    const days7 = [];
    for (let i = 6; i >= 0; i--) {
        const d = new Date(); d.setDate(d.getDate() - i);
        const ds = d.toISOString().split('T')[0];
        const dayTotal = sales.filter(s => s.date === ds).reduce((s,i) => s + (i.netTotal||0), 0);
        days7.push({ label: d.toLocaleDateString('ar-SA', {weekday:'short'}), val: dayTotal });
    }
    const maxV = Math.max(...days7.map(d => d.val), 1);
    document.getElementById('salesChart').innerHTML = days7.map(d => `
        <div class="chart-bar-wrap">
            <div class="chart-val">${d.val > 0 ? fmt(d.val) : ''}</div>
            <div class="chart-bar income" style="height:${Math.round((d.val/maxV)*120)+4}px"></div>
            <div class="chart-label">${d.label}</div>
        </div>
    `).join('');

    const sa = document.getElementById('stockAlerts');
    if (lowStock.length === 0) {
        sa.innerHTML = '<div style="text-align:center;color:var(--success);padding:20px;font-size:13px">✅ مستويات المخزون ممتازة</div>';
    } else {
        sa.innerHTML = lowStock.map(p => `
            <div class="alert ${p.qty === 0 ? 'alert-danger' : 'alert-warning'}" style="margin-bottom:8px;padding:8px 12px;font-size:12px">
                ${p.qty === 0 ? '🚫' : '⚠️'} <strong>${p.name}</strong> — الكمية: ${p.qty}
            </div>
        `).join('');
    }

    const badge = document.getElementById('alertBadge');
    if (lowStock.length > 0) { badge.style.display = ''; badge.textContent = '⚠️ ' + lowStock.length + ' تنبيه'; }
    else badge.style.display = 'none';

    const lastSales = [...sales].sort((a,b) => b.date.localeCompare(a.date)).slice(0,5);
    document.getElementById('lastSalesTable').innerHTML = `
        <thead><tr><th>رقم الفاتورة</th><th>التاريخ</th><th>العميل</th><th>الصافي</th></tr></thead>
        <tbody>${lastSales.length ? lastSales.map(i=>`<tr><td><b>${i.num}</b></td><td>${i.date}</td><td>${i.customerName||'-'}</td><td style="color:var(--success);font-weight:700">${fmt(i.netTotal)} ر.س</td></tr>`).join('') : '<tr><td colspan="4" class="empty-state">لا توجد مبيعات</td></tr>'}</tbody>
    `;

    const salesCount = {};
    sales.forEach(inv => inv.items.forEach(it => { salesCount[it.productId] = (salesCount[it.productId]||0) + it.qty; }));
    const top5 = Object.entries(salesCount).sort((a,b)=>b[1]-a[1]).slice(0,5);
    document.getElementById('topProductsTable').innerHTML = `
        <thead><tr><th>الصنف</th><th>الوحدات المباعة</th></tr></thead>
        <tbody>${top5.length ? top5.map(([pid,cnt])=>{const p=db.products.find(x=>x.id===pid);return `<tr><td>${p?p.name:pid}</td><td><b>${cnt} وحدة</b></td></tr>`;}).join('') : '<tr><td colspan="2" class="empty-state">لا توجد مبيعات</td></tr>'}</tbody>
    `;
}

// ===================== أدوات عامة =====================
function fmt(n) { return parseFloat(n||0).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g,','); }
function getTodayDate() { return new Date().toISOString().split('T')[0]; }

function toggleNotif() {
    const popup = document.getElementById('notifPopup');
    const lowStock = db.products.filter(p => p.qty <= (p.minStock || db.settings.minStock));
    popup.innerHTML = `<div style="padding:10px 16px;font-weight:700;font-size:13px;border-bottom:1px solid var(--border);color:var(--primary)">🔔 تنبيهات المخزون</div>` +
        (lowStock.length === 0 ? '<div class="notif-item">✅ المخزون سليم</div>' :
         lowStock.map(p=>`<div class="notif-item ${p.qty===0?'danger':'warning'}">${p.qty===0?'🚫':'⚠️'} <b>${p.name}</b> (${p.qty})</div>`).join(''));
    popup.classList.toggle('show');
}

document.addEventListener('click', e => {
    if (!e.target.closest('#notifPopup') && !e.target.closest('#alertBadge')) {
        document.getElementById('notifPopup').classList.remove('show');
    }
});

// ===================== فاتورة مبيعات =====================
let saleItems = [];
function initSaleForm() {
    document.getElementById('saleCustomer').innerHTML = db.customers.map(c=>`<option value="${c.id}">${c.name}</option>`).join('');
    document.getElementById('saleItemProd').innerHTML = '<option value="">-- اختر الكتاب أو المادة --</option>' + db.products.filter(p=>p.qty>0).map(p=>`<option value="${p.id}">${p.name} (المتاح: ${p.qty})</option>`).join('');
    document.getElementById('saleDate').value = getTodayDate();
    document.getElementById('saleInvNum').textContent = 'رقم المستند: ' + getNextInvNum('S');
    document.getElementById('saleVat').value = db.settings.vatPct || 15;
    saleItems = [];
    renderSaleItems();
}

function fillSaleItem() {
    const pid = document.getElementById('saleItemProd').value;
    const p = db.products.find(x => x.id === pid);
    if (p) { document.getElementById('saleItemPrice').value = p.price || 0; calcSaleItemTotal(); }
}

function calcSaleItemTotal() {
    const q = parseFloat(document.getElementById('saleItemQty').value)||0;
    const pr = parseFloat(document.getElementById('saleItemPrice').value)||0;
    document.getElementById('saleItemTotal').value = fmt(q * pr);
}

function addSaleItem() {
    const pid = document.getElementById('saleItemProd').value;
    const p = db.products.find(x => x.id === pid);
    if (!p) return alert('الرجاء تحديد صنف صحيح');
    const qty = parseInt(document.getElementById('saleItemQty').value)||0;
    if (qty <= 0) return alert('الكمية يجب أن تزيد عن صفر');
    if (qty > p.qty) return alert(`المخزون لا يكفي! المتاح: ${p.qty}`);
    const price = parseFloat(document.getElementById('saleItemPrice').value)||0;
    const existing = saleItems.find(x => x.productId === pid);
    if (existing) {
        if (existing.qty + qty > p.qty) return alert('إجمالي الكمية يتجاوز المخزون');
        existing.qty += qty; existing.total = existing.qty * existing.price;
    } else {
        saleItems.push({ productId: pid, name: p.name, qty, price, cost: p.cost||0, total: qty*price });
    }
    renderSaleItems();
}

function removeSaleItem(idx) { saleItems.splice(idx,1); renderSaleItems(); }

function renderSaleItems() {
    const list = document.getElementById('saleItemsList');
    list.innerHTML = saleItems.length ? saleItems.map((it,i) => `
        <div class="invoice-row">
            <span>${i+1}</span><span>${it.name}</span><span>${it.qty}</span>
            <span>${fmt(it.price)}</span><span style="font-weight:700">${fmt(it.total)}</span>
            <button class="btn btn-danger btn-sm" onclick="removeSaleItem(${i})">✕</button>
        </div>
    `).join('') : '<div style="padding:16px;text-align:center;color:var(--text3);font-size:13px">لم تقم بإضافة عناصر بعد</div>';
    calcSaleTotals();
}

function calcSaleTotals() {
    const subtotal = saleItems.reduce((s,it) => s + it.total, 0);
    const disc = parseFloat(document.getElementById('saleDiscount').value)||0;
    const vat = parseFloat(document.getElementById('saleVat').value)||0;
    const discAmt = subtotal * disc / 100;
    const afterDisc = subtotal - discAmt;
    const vatAmt = afterDisc * vat / 100;
    const net = afterDisc + vatAmt;
    document.getElementById('saleTotals').innerHTML = `
        <div><span class="label">الإجمالي قبل الخصم</span><span class="value">${fmt(subtotal)} ر.س</span></div>
        ${disc > 0 ? `<div><span class="label">الخصم (${disc}%)</span><span class="value" style="color:var(--danger)">- ${fmt(discAmt)} ر.س</span></div>` : ''}
        ${vat > 0 ? `<div><span class="label">ضريبة القيمة المضافة (${vat}%)</span><span class="value">${fmt(vatAmt)} ر.س</span></div>` : ''}
        <div><span class="label" style="font-weight:800;color:var(--primary)">الصافي الإجمالي</span><span class="value" style="color:var(--primary);font-size:18px">${fmt(net)} ر.س</span></div>
    `;
    return { subtotal, discAmt, vatAmt, net };
}

function saveSaleInvoice() {
    if (saleItems.length === 0) return alert('لا يمكن حفظ الفاتورة بدون بنود');
    const custId = document.getElementById('saleCustomer').value || 'cust0';
    const cust = db.customers.find(c => c.id === custId);
    const totals = calcSaleTotals();
    const invNum = getNextInvNum('S');
    const inv = {
        id: genId('SINV'), type: 'sale', num: invNum,
        date: document.getElementById('saleDate').value,
        customerId: custId, customerName: cust ? cust.name : 'عميل نقدي',
        payType: document.getElementById('salePayType').value,
        notes: document.getElementById('saleNotes').value,
        items: JSON.parse(JSON.stringify(saleItems)),
        subtotal: totals.subtotal, discAmt: totals.discAmt, vatAmt: totals.vatAmt,
        netTotal: totals.net, costTotal: saleItems.reduce((s,it)=>s+(it.cost*it.qty),0),
        discount: parseFloat(document.getElementById('saleDiscount').value)||0,
        vat: parseFloat(document.getElementById('saleVat').value)||0
    };
    saleItems.forEach(it => { const p = db.products.find(x=>x.id===it.productId); if(p) p.qty -= it.qty; });
    db.invoices.push(inv); saveDB();
    alert('✅ تم حفظ فاتورة المبيعات بنجاح برقم ' + invNum);
    clearSaleForm(); showPage('dashboard');
}

function clearSaleForm() {
    saleItems = [];
    document.getElementById('saleDiscount').value = '0';
    document.getElementById('saleNotes').value = '';
    document.getElementById('saleItemQty').value = '1';
    document.getElementById('saleItemPrice').value = '';
    document.getElementById('saleItemTotal').value = '';
    initSaleForm();
}

function previewSaleInvoice() {
    if (saleItems.length === 0) return alert('أضف عناصر أولاً');
    const totals = calcSaleTotals();
    const custId = document.getElementById('saleCustomer').value || 'cust0';
    const cust = db.customers.find(c => c.id === custId);
    const html = buildInvoiceHTML({
        type: 'sale', num: getNextInvNum('S'),
        date: document.getElementById('saleDate').value,
        personName: cust ? cust.name : 'عميل نقدي',
        payType: document.getElementById('salePayType').value,
        notes: document.getElementById('saleNotes').value,
        items: saleItems, totals, s: db.settings
    });
    const w = window.open('','_blank'); w.document.write(html); w.document.close();
}

// ===================== فاتورة مشتريات =====================
let purchItems = [];
function initPurchForm() {
    document.getElementById('purchSupplier').innerHTML = db.suppliers.length ?
        db.suppliers.map(s=>`<option value="${s.id}">${s.name}</option>`).join('') :
        '<option value="">-- أضف مورداً أولاً --</option>';
    document.getElementById('purchItemProd').innerHTML = '<option value="">-- اختر صنفاً --</option><option value="__new__">+ إضافة صنف جديد</option>' +
        db.products.map(p=>`<option value="${p.id}">${p.name}</option>`).join('');
    document.getElementById('purchDate').value = getTodayDate();
    document.getElementById('purchInvNum').textContent = 'رقم السند: ' + getNextInvNum('P');
    purchItems = []; renderPurchItems();
}

function fillPurchItem() {
    const v = document.getElementById('purchItemProd').value;
    if (v === '__new__') { openProductModal(null, true); document.getElementById('purchItemProd').value = ''; return; }
    const p = db.products.find(x=>x.id===v);
    if (p) { document.getElementById('purchItemCost').value = p.cost||0; calcPurchItemTotal(); }
}

function calcPurchItemTotal() {
    const q = parseFloat(document.getElementById('purchItemQty').value)||0;
    const c = parseFloat(document.getElementById('purchItemCost').value)||0;
    document.getElementById('purchItemTotal').value = fmt(q*c);
}

function addPurchItem() {
    const pid = document.getElementById('purchItemProd').value;
    if (!pid || pid==='__new__') return alert('يرجى اختيار صنف');
    const p = db.products.find(x=>x.id===pid);
    if (!p) return alert('لم يتم العثور على الصنف');
    const qty = parseInt(document.getElementById('purchItemQty').value)||0;
    const cost = parseFloat(document.getElementById('purchItemCost').value)||0;
    if (qty <= 0) return alert('الكمية يجب أن تكون وحدة فأكثر');
    const existing = purchItems.find(x=>x.productId===pid);
    if (existing) { existing.qty += qty; existing.total = existing.qty * existing.cost; }
    else purchItems.push({ productId: pid, name: p.name, qty, cost, total: qty*cost });
    renderPurchItems();
}

function removePurchItem(idx) { purchItems.splice(idx,1); renderPurchItems(); }

function renderPurchItems() {
    document.getElementById('purchItemsList').innerHTML = purchItems.length ? purchItems.map((it,i) => `
        <div class="invoice-row">
            <span>${i+1}</span><span>${it.name}</span><span>${it.qty}</span>
            <span>${fmt(it.cost)}</span><span style="font-weight:700">${fmt(it.total)}</span>
            <button class="btn btn-danger btn-sm" onclick="removePurchItem(${i})">✕</button>
        </div>
    `).join('') : '<div style="padding:16px;text-align:center;color:var(--text3);font-size:13px">لم يتم إضافة أي بنود</div>';
    const sub = purchItems.reduce((s,it)=>s+it.total,0);
    document.getElementById('purchTotals').innerHTML = `
        <div><span class="label" style="font-weight:800;color:var(--primary)">إجمالي تكلفة المشتريات</span><span class="value" style="color:var(--primary);font-size:18px">${fmt(sub)} ر.س</span></div>
    `;
}

function savePurchInvoice() {
    if (purchItems.length === 0) return alert('الرجاء إدراج بنود التوريد أولاً');
    const suppId = document.getElementById('purchSupplier').value;
    if (!suppId) return alert('الرجاء تعيين المورد');
    const supp = db.suppliers.find(s=>s.id===suppId);
    const sub = purchItems.reduce((s,it)=>s+it.total,0);
    const invNum = getNextInvNum('P');
    const inv = {
        id: genId('PINV'), type: 'purchase', num: invNum,
        date: document.getElementById('purchDate').value,
        supplierId: suppId, supplierName: supp ? supp.name : 'مورد غير محدد',
        extNum: document.getElementById('purchExtNum').value,
        payType: document.getElementById('purchPayType').value,
        notes: document.getElementById('purchNotes').value,
        items: JSON.parse(JSON.stringify(purchItems)), netTotal: sub
    };
    purchItems.forEach(it => {
        const p = db.products.find(x=>x.id===it.productId);
        if (p) { p.qty += it.qty; p.cost = it.cost; }
    });
    db.invoices.push(inv); saveDB();
    alert('✅ تم حفظ مستند التوريد برقم ' + invNum);
    clearPurchForm(); showPage('invoices');
}

function clearPurchForm() {
    purchItems = [];
    document.getElementById('purchExtNum').value = '';
    document.getElementById('purchNotes').value = '';
    initPurchForm();
}

function getNextInvNum(type) {
    const prefix = type === 'S' ? 'S' : 'P';
    const last = db.invoices.filter(i=>i.num&&i.num.startsWith(prefix)).map(i=>parseInt(i.num.replace(prefix,''))||0);
    return prefix + String((last.length ? Math.max(...last) : 0) + 1).padStart(5,'0');
}

// ===================== سجل الفواتير =====================
function renderInvoices() {
    const type = document.getElementById('invFilterType').value;
    const month = document.getElementById('invFilterMonth').value;
    let invs = [...db.invoices].sort((a,b)=>b.date.localeCompare(a.date));
    if (type) invs = invs.filter(i=>i.type===type);
    if (month) invs = invs.filter(i=>i.date.startsWith(month));
    document.getElementById('invoicesTable').innerHTML = `
        <thead><tr><th>رقم الحركة</th><th>النوع</th><th>التاريخ</th><th>الطرف</th><th>الصافي</th><th>الدفع</th><th>عمليات</th></tr></thead>
        <tbody>${invs.length ? invs.map(i=>`
            <tr>
                <td><b>${i.num}</b></td>
                <td><span class="badge ${i.type==='sale'?'badge-success':'badge-info'}">${i.type==='sale'?'بيع':'شراء'}</span></td>
                <td>${i.date}</td>
                <td>${i.customerName||i.supplierName||'-'}</td>
                <td style="font-weight:700;color:${i.type==='sale'?'var(--success)':'var(--danger)'}">${fmt(i.netTotal)} ر.س</td>
                <td>${payLabel(i.payType)}</td>
                <td>
                    <button class="btn btn-outline btn-sm" onclick="printInvoice('${i.id}')">🖨️ طباعة</button>
                    <button class="btn btn-danger btn-sm" onclick="deleteInvoice('${i.id}')">🗑️ حذف</button>
                </td>
            </tr>
        `).join('') : '<tr><td colspan="7" class="empty-state">لا توجد سجلات</td></tr>'}</tbody>
    `;
}

function payLabel(t) {
    const m = { cash:'نقدي', card:'بطاقة', credit:'آجل', transfer:'تحويل' };
    return m[t] || t || '-';
}

function deleteInvoice(id) {
    if (!confirm('هل تود حذف هذه الفاتورة؟')) return;
    db.invoices = db.invoices.filter(i=>i.id!==id); saveDB(); renderInvoices();
}

function printInvoice(id) {
    const inv = db.invoices.find(i=>i.id===id);
    if (!inv) return;
    const totals = { subtotal: inv.subtotal||inv.netTotal, discAmt: inv.discAmt||0, vatAmt: inv.vatAmt||0, net: inv.netTotal };
    const html = buildInvoiceHTML({ type:inv.type, num:inv.num, date:inv.date, personName:inv.customerName||inv.supplierName||'-', payType:inv.payType, notes:inv.notes, items:inv.items, totals, s:db.settings });
    const w = window.open('','_blank'); w.document.write(html); w.document.close();
}

function buildInvoiceHTML({type, num, date, personName, payType, notes, items, totals, s}) {
    return `<!DOCTYPE html><html lang="ar" dir="rtl"><head><meta charset="UTF-8"><title>مستند رقم ${num}</title>
    <style>body{font-family:Tahoma,Arial,sans-serif;margin:0;padding:30px;direction:rtl;color:#1a2332;font-size:13px}.inv-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:30px;border-bottom:3px solid #1a3a5c;padding-bottom:16px}.inv-company{font-size:22px;font-weight:800;color:#1a3a5c}.inv-sub{font-size:12px;color:#666;margin-top:4px}.inv-title{font-size:24px;font-weight:800;color:#1a3a5c;text-align:left}.inv-num{font-size:14px;color:#444;text-align:left;margin-top:6px}.inv-info{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:24px;background:#f8f9fa;padding:16px;border-radius:8px;border:1px solid #eee}table{width:100%;border-collapse:collapse;margin:20px 0}th{background:#1a3a5c;color:white;padding:10px 14px;text-align:right}td{padding:10px 14px;border-bottom:1px solid #eee}.total-section{padding-top:12px;display:flex;flex-direction:column;align-items:flex-end;gap:6px}.total-row{display:flex;justify-content:space-between;width:280px;font-size:13px;border-bottom:1px dashed #ddd;padding:4px 0}.total-row.grand{font-size:18px;font-weight:800;color:#1a3a5c;border-bottom:none;border-top:2px solid #1a3a5c;padding-top:8px}.footer{margin-top:50px;text-align:center;font-size:11px;color:#999;border-top:1px solid #eee;padding-top:12px}@media print{body{padding:0}}</style></head><body>
    <div class="inv-header">
        <div><div class="inv-company">${s.storeName||'نظام حسابات المكتبة'}</div><div class="inv-sub">${s.address||''}</div><div class="inv-sub">هاتف: ${s.phone||'-'}</div>${s.vatNum?`<div class="inv-sub">الرقم الضريبي: ${s.vatNum}</div>`:''}</div>
        <div><div class="inv-title">${type==='sale'?'فاتورة مبيعات ضريبية':'سند استلام مشتريات'}</div><div class="inv-num">الرقم: ${num}</div><div class="inv-num">التاريخ: ${date}</div></div>
    </div>
    <div class="inv-info">
        <div><label>${type==='sale'?'العميل':'المورد'}:</label> ${personName}</div>
        <div><label>طريقة السداد:</label> ${payLabel(payType)}</div>
        ${notes?`<div style="grid-column:span 2"><label>ملاحظات:</label> ${notes}</div>`:''}
    </div>
    <table><thead><tr><th>#</th><th>الصنف</th><th>الكمية</th><th>سعر الوحدة</th><th>الإجمالي</th></tr></thead>
    <tbody>${items.map((it,i)=>`<tr><td>${i+1}</td><td><b>${it.name}</b></td><td>${it.qty}</td><td>${fmt(it.price||it.cost||0)} ريال</td><td>${fmt(it.total)} ريال</td></tr>`).join('')}</tbody></table>
    <div class="total-section">
        <div class="total-row"><span>الإجمالي قبل الخصم</span><span>${fmt(totals.subtotal)} ريال</span></div>
        ${totals.discAmt>0?`<div class="total-row"><span>الخصم</span><span>- ${fmt(totals.discAmt)} ريال</span></div>`:''}
        ${totals.vatAmt>0?`<div class="total-row"><span>ضريبة القيمة المضافة</span><span>+ ${fmt(totals.vatAmt)} ريال</span></div>`:''}
