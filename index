        .chart-bar-container { display:flex; align-items:flex-end; gap:16px; height:160px; padding:10px 8px; }
        .chart-bar-wrap { flex:1; display:flex; flex-direction:column; align-items:center; gap:4px; height:100%; justify-content:flex-end; }
        .chart-bar { width:100%; background:var(--primary-light); border-radius:4px 4px 0 0; min-height:4px; transition:height 0.5s; }
        .chart-bar.income { background:var(--success); }
