                        div class=card
                            div class=card-headerspan class=card-title🧾 آخر عمليات البيعspandiv
                            div class=card-body style=padding0
                                div class=table-wraptable id=lastSalesTabletablediv
                            div
                        div
                        div class=card
                            div class=card-headerspan class=card-title📗 السلع الأكثر مبيعاًspandiv
                            div class=card-body style=padding0
                                div class=table-wraptable id=topProductsTabletablediv
                            div
                        div
                    div
                div

                !-- ===== فاتورة بيع ===== --
                div class=page id=page-sale
                    div class=card mb-24
                        div class=card-header
                            span class=card-title🧾 إنشاء فاتورة مبيعات جديدةspan
                            span style=font-size12px;colorvar(--text3) id=saleInvNumspan
                        div
                        div class=card-body
                            div class=form-grid form-grid-3 mb-16
                                div class=form-group
