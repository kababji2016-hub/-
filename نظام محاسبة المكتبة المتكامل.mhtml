    !-- النوافذ المنبثقة الموحدة (MODALS) --
    div id=modalOverlay class=modal-overlay style=displaynone onclick=closeModal(event)
        div class=modal id=modalBox
            div class=modal-header
                span class=modal-title id=modalTitleعنوان النافذةspan
                button class=modal-close onclick=closeModalNow()✕button
            div
            div class=modal-body id=modalBodydiv
            div class=modal-footer id=modalFooterdiv
