                                        option value=creditآجلoption
                                        option value=transferتحويلoption
                                    select
                                div
                                div class=form-group
                                    labelملاحظاتlabel
                                    input type=text class=form-control id=purchNotes placeholder=أي تفاصيل إضافية...
                                div
                            div

                            div style=displayflex;gap12px
                                button class=btn btn-success onclick=savePurchInvoice()✅ حفظ الفاتورة وإدخال المستودعbutton
                                button class=btn btn-outline onclick=clearPurchForm()🗑️ مسحbutton
                            div
                        div
