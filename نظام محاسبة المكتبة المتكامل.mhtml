            document.getElementById('modalTitle').textContent = c  'تعديل الفئة'  'إضافة تصنيف مخزني جديد';
            document.getElementById('modalBody').innerHTML = `div class=form-grouplabelاسم المجموعة  التصنيف الجديدlabelinput type=text class=form-control id=catName value=${cc.name''}div`;
            document.getElementById('modalFooter').innerHTML = `button class=btn btn-outline onclick=closeModalNow()إلغاءbuttonbutton class=btn btn-primary onclick=saveCat('${id''}')💾 حفظ البياناتbutton`;
            document.getElementById('modalOverlay').style.display = 'flex';
        }

        function saveCat(id) {
            const name = document.getElementById('catName').value.trim();
            if (!name) return alert('الرجاء كتابة اسم الفئة المراد إنشاؤها');
            
            if (id) {
                const c = db.categories.find(x = x.id === id);
                if (c) c.name = name;
            } else {
                db.categories.push({ id genId('CAT'), name });
            }
            saveDB();
            closeModalNow();
            renderCategories();
        }

        function deleteCat(id) {
            if (!confirm('حذف الفئة لا يسقط السلع المرتبطة بها بل يحولها لأصناف غير مصنفة، هل تريد الإزالة؟')) return;
            db.categories = db.categories.filter(x = x.id !== id);
            saveDB();
            renderCategories();
        }

         ===================== أطراف الشركة (الزبائن والموردين) =====================
        function renderCustomers() {
            const q = (document.getElementById('custSearch').value'').toLowerCase();
            let custs = db.customers.filter(c = c.name.toLowerCase().includes(q)  (c.phone'').includes(q));
            
            document.getElementById('customersTable').innerHTML = `
                theadtrthاسم العميلththرقم جوال العميلththالعنوان والمدينةththمسحوبات مبيعاته الإجماليةththعمليات وتحكمthtrthead
                tbody${custs.map(c = {
                    const totalSales = db.invoices.filter(i = i.type==='sale' && i.customerId===c.id).reduce((s,i) = s + (i.netTotal0), 0);
                    return `tr
                        tdb${c.name}btd
                        td${c.phone  '-'}td
                        td${c.address  '-'}td
                        td style=font-weight700;colorvar(--success)${fmt(totalSales)} ر.سtd
                        td
                            button class=btn btn-outline btn-sm onclick=openPersonModal('customer','${c.id}')✏️ تعديلbutton
                            ${c.id !== 'cust0'  `button class=btn btn-danger btn-sm onclick=deletePerson('customer','${c.id}')🗑️button`''}
                        td
                    tr`;
                }).join('')}tbody
            `;
        }

        function renderSuppliers() {
            const q = (document.getElementById('suppSearch').value'').toLowerCase();
            let supps = db.suppliers.filter(s = s.name.toLowerCase().includes(q)  (s.phone'').includes(q));
            
            document.getElementById('suppliersTable').innerHTML = `
                theadtrthاسم المورد  دار التوزيعththرقم الجوال والاتصالththالعنوان البريديththإجمالي التوريدات منهththعملياتthtrthead
                tbody${supps.length  supps.map(s = {
                    const totalPurch = db.invoices.filter(i = i.type==='purchase' && i.supplierId===s.id).reduce((sum,i) = sum + (i.netTotal0), 0);
                    return `tr
                        tdb${s.name}btd
                        td${s.phone  '-'}td
                        td${s.address  '-'}td
                        td style=font-weight700;colorvar(--info)${fmt(totalPurch)} ر.سtd
                        td
                            button class=btn btn-outline btn-sm onclick=openPersonModal('supplier','${s.id}')✏️ تعديلbutton
                            button class=btn btn-danger btn-sm onclick=deletePerson('supplier','${s.id}')🗑️button
                        td
                    tr`;
                }).join('')  'trtd colspan=5 class=empty-stateلا يوجد أي مورد معتمد مضاف حالياًtdtr'}tbody
            `;
        }

        function openPersonModal(type, id) {
            const arr = type === 'customer'  db.customers  db.suppliers;
            const item = id  arr.find(x = x.id === id)  null;
            const lbl = type === 'customer'  'الزبون  العميل'  'الشركة الموردة';
            
            document.getElementById('modalTitle').textContent = (item  'تعديل بيانات '  'إضافة وتهيئة ') + lbl;
            document.getElementById('modalBody').innerHTML = `
                div class=form-grid
                    div class=form-grouplabelالاسم الكامل  الاسم التجاري المعتمد labelinput type=text class=form-control id=perName value=${itemitem.name''} requireddiv
                    div class=form-grouplabelرقم هاتف الاتصال  الجوالlabelinput type=text class=form-control id=perPhone value=${itemitem.phone''''}div
                    div class=form-grouplabelتفاصيل العنوان الوطني  الفروعlabelinput type=text class=form-control id=perAddress value=${itemitem.address''''}div
                div
            `;
            
            document.getElementById('modalFooter').innerHTML = `
                button class=btn btn-outline onclick=closeModalNow()إغلاق النافذةbutton
                button class=btn btn-primary onclick=savePerson('${type}', '${id''}')💾 حفظ البيانات للأطرافbutton
            `;
            document.getElementById('modalOverlay').style.display = 'flex';
        }

        function savePerson(type, id) {
            const name = document.getElementById('perName').value.trim();
            if (!name) return alert('الاسم الكامل هو حقل أساسي إلزامي');
            
            const arr = type === 'customer'  db.customers  db.suppliers;
            const data = {
                id id  genId(type === 'customer'  'CST'  'SPL'),
                name,
                phone document.getElementById('perPhone').value.trim(),
                address document.getElementById('perAddress').value.trim()
            };

            if (id) {
                const idx = arr.findIndex(x = x.id === id);
                if (idx = 0) arr[idx] = data;
            } else {
                arr.push(data);
            }
            
            saveDB();
            closeModalNow();
            type === 'customer'  renderCustomers()  renderSuppliers();
        }

        function deletePerson(type, id) {
            if (!confirm('هل تود استبعاد وحذف هذا الطرف نهائياً من سجلاتك التجارية؟')) return;
            if (type === 'customer') {
                db.customers = db.customers.filter(x = x.id !== id);
                renderCustomers();
            } else {
                db.suppliers = db.suppliers.filter(x = x.id !== id);
                renderSuppliers();
            }
            saveDB();
        }

         ===================== نظام تقييد وإدارة قيود المصروفات =====================
        function addExpense() {
            const desc = document.getElementById('expDesc').value.trim();
            const amount = parseFloat(document.getElementById('expAmount').value)0;
            const category = document.getElementById('expCat').value;
            const date = document.getElementById('expDate').value;
            
            if (!desc  amount = 0  !date) return alert('يرجى استيفاء الحقول والمبلغ بشكل صحيح تزيد عن صفر');
            
            db.expenses.push({ id genId('EXP'), desc, amount, category, date });
            saveDB();
            alert('✅ جرى إثبات قيد المصرف المالي وخفض الصندوق التقديري المالي.');
            
            document.getElementById('expDesc').value = '';
            document.getElementById('expAmount').value = '';
            renderExpenses();
        }

        function renderExpenses() {
            document.getElementById('expDate').value = getTodayDate();
            const filterMonth = document.getElementById('expFilter').value  getTodayDate().slice(0,7);
            document.getElementById('expFilter').value = filterMonth;
            
            const list = db.expenses.filter(e = e.date.startsWith(filterMonth));
            const sumEx = list.reduce((s, e) = s + e.amount, 0);

            document.getElementById('expensesTable').innerHTML = `
                theadtrthالتاريخththبيان النفقة وقيد المصرفththالفئة الهيكليةththالمبلغ المدفوعththإجراءاتthtrthead
                tbody${list.length  list.map(e = `
                    tr
                        td${e.date}td
                        tdb${e.desc}btd
                        tdspan class=badge badge-warning${e.category}spantd
                        td style=font-weight700;colorvar(--danger)${fmt(e.amount)} ر.سtd
                        tdbutton class=btn btn-danger btn-sm onclick=deleteExpense('${e.id}')🗑️ شطبbuttontd
                    tr
                `).join('')  'trtd colspan=5 class=empty-stateلم يتم تدوين قيود نفقات خلال هذا الشهر الحالي بعدtdtr'}
                tr style=background#f1f3f5;font-weightboldtd colspan=3 class=text-leftمجموع النفقات الخارجة الكلي للشهرtdtd style=colorvar(--danger);font-size14px${fmt(sumEx)} ريال سtdtdtdtr
                tbody
            `;
        }

        function deleteExpense(id) {
            if (!confirm('هل تريد شطب قيد هذا المصرف نهائياً؟')) return;
            db.expenses = db.expenses.filter(e = e.id !== id);
            saveDB();
            renderExpenses();
        }

         ===================== قسم الإعدادات العامة والتهيئة المتقدمة المنشأة =====================
        function renderSettings() {
            document.getElementById('setStoreName').value = db.settings.storeName  '';
            document.getElementById('setPhone').value = db.settings.phone  '';
            document.getElementById('setAddress').value = db.settings.address  '';
            document.getElementById('setVatNum').value = db.settings.vatNum  '';
            document.getElementById('setMinStock').value = db.settings.minStock  5;
            document.getElementById('setVatPct').value = db.settings.vatPct  15;
            
            document.getElementById('usersList').innerHTML = db.users.map(u = `
                div style=displayflex; justify-contentspace-between; align-itemscenter; padding8px; border-bottom1px solid var(--border)
                    span👤 b${u.username}b — صلاحية [${u.role === 'admin'  'مدير كامل'  'كاشير مبيعات'}]span
                    ${u.username !== 'admin'  `button class=btn btn-danger btn-sm onclick=deleteUser('${u.username}')تعطيل وحسابbutton`  'small style=colorvar(--text3)الحساب الأساسي محميsmall'}
                div
            `).join('');
        }

        function saveSettings() {
            db.settings = {
                storeName document.getElementById('setStoreName').value.trim(),
                phone document.getElementById('setPhone').value.trim(),
                address document.getElementById('setAddress').value.trim(),
                vatNum document.getElementById('setVatNum').value.trim(),
                minStock parseInt(document.getElementById('setMinStock').value)  5,
                vatPct parseFloat(document.getElementById('setVatPct').value)  0
            };
            document.getElementById('storeName').textContent = db.settings.storeName;
            saveDB();
            alert('✅ جرى حفظ التهيئة والمقاييس الجديدة في ملف النظام بنجاح.');
        }

        function saveUser() {
            const u = document.getElementById('newUsername').value.trim();
            const p = document.getElementById('newPassword').value;
            const r = document.getElementById('newRole').value;
            
            if (!u  !p) return alert('الرجاء تعبئة بيانات اسم الحساب الرقمي السري');
            if(db.users.some(x = x.username === u)) return alert('اسم المستخدم مسجل مسبقاً بنظام الحسابات الحالية');
            
            db.users.push({ username u, password p, role r });
            saveDB();
            document.getElementById('newUsername').value = '';
            document.getElementById('newPassword').value = '';
            renderSettings();
            alert('✅ جرى إنشاء مستخدم جديد بنجاح.');
        }

        function deleteUser(username) {
            if (!confirm(`هل تود حظر وحذف المستخدم [${username}]؟`)) return;
            db.users = db.users.filter(x = x.username !== username);
            saveDB();
            renderSettings();
        }

         ===================== أدوات السلامة والنسخ الاحتياطي للأمان =====================
        function backupData() {
            try {
                const rawStr = btoa(unescape(encodeURIComponent(JSON.stringify(db))));
                const dataUri = 'dataapplicationjson;charset=utf-8;base64,' + rawStr;
                
                const exportFileDefaultName = 'محفوظات_نظام_المكتبة_' + new Date().toISOString().split('T')[0] + '.json';
                const linkElement = document.createElement('a');
                linkElement.setAttribute('href', dataUri);
                linkElement.setAttribute('download', exportFileDefaultName);
                linkElement.click();
            } catch(e) {
                alert(تعذر إنشاء ملف تصدير البيانات  + e.message);
            }
        }

        function importBackup() {
            if (confirm(تحذير حرج للغاية استعادة قاعدة بيانات سابقة سيؤدي لمسح وحذف كافة العمليات المدونة الحالية وإحلال البيانات القديمة مكانها بالكامل، هل أنت متأكد من المتابعة؟)) {
                document.getElementById('importFile').click();
            }
        }

        function doImport(e) {
            const file = e.target.files[0];
            if (!file) return;
            
            const reader = new FileReader();
            reader.onload = function(evt) {
                try {
                    let rawData = evt.target.result;
                     فحص إذا كان الملف مشفر أو نص عادي
                    if (!rawData.trim().startsWith('{')) {
                        rawData = decodeURIComponent(escape(atob(rawData.trim())));
                    }
                    const parsed = JSON.parse(rawData);
                    
                    if (parsed.settings && parsed.users) {
                        db = parsed;
                        saveDB();
                        alert(✅ تهانينا، تم استعادة وتكامل قاعدة البيانات بنجاح، سيقوم المتصفح بإعادة التشغيل فورا.);
                        location.reload();
                    } else {
                        alert(فشل الاستيراد هيكلية بنية الملف المختار غير متطابقة مع هذا الإصدار البرمي المعتمد.);
                    }
                } catch(err) {
                    alert(عذراً، تعذر فك تشفير وقراءة الملف المختار بشكل سليم  + err.message);
                }
            };
            reader.readAsText(file);
        }

         ===================== تهيئة إغلاق النوافذ (MODAL LOGIC) الموحدة =====================
        function closeModal(e) { if(e.target.id === 'modalOverlay') closeModalNow(); }
        function closeModalNow() { document.getElementById('modalOverlay').style.display = 'none'; }
        
        function initApp() {
            loadDB();
            document.getElementById('storeName').textContent = db.settings.storeName;
            renderDashboard();
        }
        
         التحميل الأولي الهادئ عند فتح الصفحة المباشرة
        window.onload = () = { loadDB(); };
    script
