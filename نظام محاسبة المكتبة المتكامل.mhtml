            div class=content
                !-- ===== لوحة التحكم ===== --
                div class=page active id=page-dashboard
                    div class=stats-grid id=dashStatsdiv
                    div style=displaygrid;grid-template-columns2fr 1fr;gap16px;margin-bottom24px
                        div class=card
                            div class=card-headerspan class=card-title📈 مبيعات آخر 7 أيامspandiv
                            div class=card-body
                                div class=chart-bar-container id=salesChartdiv
                            div
                        div
                        div class=card
                            div class=card-headerspan class=card-title⚠️ تنبيهات المخزون المنخفضspandiv
                            div class=card-body id=stockAlerts style=max-height220px;overflow-yautodiv
                        div
                    div
