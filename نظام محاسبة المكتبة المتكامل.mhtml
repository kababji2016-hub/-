        function printInvoice(id) {
            const inv = db.invoices.find(i = i.id === id);
            if (!inv) return;
            const s = db.settings;
            const totals = { subtotal inv.subtotal  inv.netTotal, discAmt inv.discAmt  0, vatAmt inv.vatAmt  0, net inv.netTotal };
            
            const html = buildInvoiceHTML({
                type inv.type,
                num inv.num,
                date inv.date,
                personName inv.customerName  inv.supplierName  '-',
                payType inv.payType,
                notes inv.notes,
                items inv.items,
                totals,
                s
            });
            const w = window.open('', '_blank');
            w.document.write(html);
            w.document.close();
        }

