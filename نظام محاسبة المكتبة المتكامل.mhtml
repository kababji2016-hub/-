        function saveProduct(id, fromPurch) {
            const name = document.getElementById('pmName').value.trim();
            if (!name) return alert('يجب تعيين وتسمية بيان الصنف لإتمام تكويده');
            
            const prod = {
                id id  genId('PRD'),
                name,
                barcode document.getElementById('pmBarcode').value.trim(),
                categoryId document.getElementById('pmCat').value,
                author document.getElementById('pmAuthor').value.trim(),
                qty parseInt(document.getElementById('pmQty').value)0,
                minStock parseInt(document.getElementById('pmMin').value)5,
                cost parseFloat(document.getElementById('pmCost').value)0,
                price parseFloat(document.getElementById('pmPrice').value)0,
                desc document.getElementById('pmDesc').value.trim()
            };

            if (id) {
                const idx = db.products.findIndex(x = x.id === id);
                if (idx = 0) db.products[idx] = prod;
            } else {
                db.products.push(prod);
            }
            
            saveDB();
            closeModalNow();
            if (fromPurch) {
                initPurchForm();
            } else {
                renderProducts();
            }
        }

        function deleteProduct(id) {
            if (!confirm('هل تود حذف هذه السلعة نهائياً من كشوف المستودعات؟')) return;
            db.products = db.products.filter(x = x.id !== id);
            saveDB();
            renderProducts();
        }

