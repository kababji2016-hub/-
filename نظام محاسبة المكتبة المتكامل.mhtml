        function deleteInvoice(id) {
            if (!confirm('تحذير حذف الفاتورة يسقط قيدها المالي فقط ولا يؤثر على تراجع حركة مستودع السلع الحالي لسلامة الفترات، هل تود الاستمرار؟')) return;
            db.invoices = db.invoices.filter(i = i.id !== id);
