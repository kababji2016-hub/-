        let purchItems = [];
        function initPurchForm() {
            if(db.suppliers.length === 0) {
                document.getElementById('purchSupplier').innerHTML = 'option value=-- الرجاء إضافة مورد أولاً من قسم الأطراف --option';
            } else {
                document.getElementById('purchSupplier').innerHTML = db.suppliers.map(s=`option value=${s.id}${s.name}option`).join('');
            }
            document.getElementById('purchItemProd').innerHTML = 'option value=-- اختر صنفاً للتوريد --optionoption value=__new__+ تسجيل وإضافة صنف جديد تماماًoption' + db.products.map(p=`option value=${p.id}${p.name}option`).join('');
            document.getElementById('purchDate').value = getTodayDate();
            document.getElementById('purchInvNum').textContent = 'رقم السند ' + getNextInvNum('P');
            purchItems = [];
            renderPurchItems();
        }

        function fillPurchItem() {
            const v = document.getElementById('purchItemProd').value;
            if (v === '__new__') {
                openProductModal(null, true);
                document.getElementById('purchItemProd').value = '';
                return;
            }
            const p = db.products.find(x = x.id === v);
            if (p) {
                document.getElementById('purchItemCost').value = p.cost  0;
                calcPurchItemTotal();
            }
        }

        function calcPurchItemTotal() {
            const q = parseFloat(document.getElementById('purchItemQty').value)0;
            const c = parseFloat(document.getElementById('purchItemCost').value)0;
            document.getElementById('purchItemTotal').value = fmt(q  c);
        }

        function addPurchItem() {
            const pid = document.getElementById('purchItemProd').value;
            if (!pid  pid === '__new__') return alert('يرجى اختيار صنف صحيح من القائمة المتاحة');
            const p = db.products.find(x = x.id === pid);
            if (!p) return alert('لم يتم العثور على الصنف المختار');
            
            const qty = parseInt(document.getElementById('purchItemQty').value)0;
            const cost = parseFloat(document.getElementById('purchItemCost').value)0;
            if (qty = 0) return alert('كمية الشراء يجب أن تكون وحدة فأكثر');
            
            const existing = purchItems.find(x = x.productId === pid);
            if (existing) {
                existing.qty += qty;
                existing.total = existing.qty  existing.cost;
            } else {
                purchItems.push({ productId pid, name p.name, qty, cost, total qty  cost });
            }
            renderPurchItems();
        }

        function removePurchItem(idx) {
            purchItems.splice(idx, 1);
            renderPurchItems();
        }

        function renderPurchItems() {
            document.getElementById('purchItemsList').innerHTML = purchItems.map((it, i) = `
                div class=invoice-row
                    span${i+1}spanspan${it.name}spanspan${it.qty}span
                    span${fmt(it.cost)}spanspan style=font-weight700${fmt(it.total)}span
                    button class=btn btn-danger btn-sm onclick=removePurchItem(${i})✕button
                div
            `).join('')  'div style=padding16px;text-aligncenter;colorvar(--text3);font-size13pxلم يتم إضافة أي بنود شراء في القائمة الحاليةdiv';
            
            const sub = purchItems.reduce((s, it) = s + it.total, 0);
            document.getElementById('purchTotals').innerHTML = `
                divspan class=label style=font-weight800;colorvar(--primary)إجمالي تكلفة المشترياتspanspan class=value style=colorvar(--primary);font-size18px${fmt(sub)} ر.سspandiv
            `;
        }

        function savePurchInvoice() {
            if (purchItems.length === 0) return alert('الرجاء إدراج بنود التوريد أولاً');
            const suppId = document.getElementById('purchSupplier').value;
            if(!suppId) return alert('الرجاء تعيين المورد لإتمام العملية القيود الماليّة');
            const supp = db.suppliers.find(s = s.id === suppId);
            const sub = purchItems.reduce((s, it) = s + it.total, 0);
            const invNum = getNextInvNum('P');

            const inv = {
                id genId('PINV'),
                type 'purchase',
                num invNum,
                date document.getElementById('purchDate').value,
                supplierId suppId,
                supplierName supp  supp.name  'مورد غير محدد',
                extNum document.getElementById('purchExtNum').value,
                payType document.getElementById('purchPayType').value,
                notes document.getElementById('purchNotes').value,
                items JSON.parse(JSON.stringify(purchItems)),
                netTotal sub
            };

             ترحيل الكميات وتعديل المتوسط المرجح للتكلفة
            purchItems.forEach(it = {
                const p = db.products.find(x = x.id === it.productId);
                if (p) {
                    p.qty += it.qty;
                    p.cost = it.cost;  تحديث التكلفة لآخر شراء
                }
            });

            db.invoices.push(inv);
            saveDB();
            alert('✅ تم حفظ مستند التوريد بنجاح برقم ' + invNum + ' وجرى زيادة المخازن فورا.');
            clearPurchForm();
            showPage('invoices');
        }

        function clearPurchForm() {
            purchItems = [];
            document.getElementById('purchExtNum').value = '';
            document.getElementById('purchNotes').value = '';
            initPurchForm();
        }

        function getNextInvNum(type) {
            const prefix = type === 'S'  'S'  'P';
            const last = db.invoices.filter(i = i.num && i.num.startsWith(prefix)).map(i = parseInt(i.num.replace(prefix, ''))  0);
            return prefix + String((last.length  Math.max(...last)  0) + 1).padStart(5, '0');
        }

