    div

    !-- التحكم بملفات الاستعادة الخلفية غير المرئية --
    input type=file id=importFile accept=.json style=displaynone onchange=doImport(event)

    script
         ===================== محرك إدارة قاعدة البيانات الافتراضية المحلية =====================
        const DB_KEY = 'libsys_v2';
        let db = {};

        function loadDB() {
            try {
                const raw = localStorage.getItem(DB_KEY);
                if (raw) {
                    db = JSON.parse(atob(raw));
                }
            } catch(e) { console.error(تعذر قراءة قاعدة البيانات المحلية الحالية, e); }
            
            if (!db.settings) db.settings = { storeName'مكتبة النور والشرق', phone'', address'', vatNum'', minStock5, vatPct15 };
            if (!db.users) db.users = [{ username'admin', password'1234', role'admin' }];
            if (!db.categories) db.categories = [{ id'cat1', name'كتب علمية وروايات' }, { id'cat2', name'قرطاسية وأدوات مكتبية' }];
            if (!db.products) db.products = [];
            if (!db.customers) db.customers = [{ id'cust0', name'عميل نقدي عام', phone'', address'' }];
            if (!db.suppliers) db.suppliers = [];
            if (!db.invoices) db.invoices = [];
            if (!db.expenses) db.expenses = [];
            saveDB();
        }

        function saveDB() {
            try {
                localStorage.setItem(DB_KEY, btoa(unescape(encodeURIComponent(JSON.stringify(db)))));
            } catch(e) {
                alert('عذراً، فشل محرك المتصفح في حفظ البيانات الحالية ' + e.message);
            }
        }

        function genId(prefix) {
            return prefix + '_' + Date.now() + '_' + Math.random().toString(36).substr(2,4);
        }

         ===================== إدارة الدخول وحفظ الجلسات =====================
        let currentUser = null;
        function doLogin() {
            const u = document.getElementById('loginUser').value.trim();
            const p = document.getElementById('loginPass').value;
            const user = db.users.find(x = x.username === u && x.password === p);
            
            if (user) {
                currentUser = user;
                document.getElementById('loginScreen').style.display = 'none';
                document.getElementById('app').style.display = 'flex';
                document.getElementById('topbarUser').textContent = '👤 ' + user.username + ' (' + (user.role === 'admin'  'مدير عام'  'كاشير') + ')';
                document.getElementById('loginErr').style.display = 'none';
                initApp();
            } else {
                document.getElementById('loginErr').style.display = 'block';
            }
        }

        function doLogout() {
            currentUser = null;
            document.getElementById('loginScreen').style.display = 'flex';
            document.getElementById('app').style.display = 'none';
            document.getElementById('loginPass').value = '';
        }

         ===================== محرك التوجيه (ROUTING) والصفحات =====================
        const pageTitles = {
            dashboard 'لوحة التحكم والمؤشرات الرقمية',
            sale 'إنشاء فاتورة مبيعات جديدة',
            purchase 'إثبات فاتورة مشتريات وموردين',
            invoices 'الأرشيف والسجل العام للفواتير',
            products 'دليل السلع والأصناف الدائم',
            categories 'تصنيفات ومجموعات المواد',
            customers 'إدارة الزبائن والعملاء',
            suppliers 'دليل جهات التوريد والموردين',
            expenses 'حساب القيود والمصروفات الإدارية',
            settings 'تهيئة إعدادات النظام والهوية'
        };

        function showPage(name) {
            document.querySelectorAll('.page').forEach(p = p.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(n = n.classList.remove('active'));
            
            const targetPage = document.getElementById('page-' + name);
            if(targetPage) targetPage.classList.add('active');
            
            document.querySelectorAll('.nav-item').forEach(n = {
                if (n.getAttribute('onclick') && n.getAttribute('onclick').includes(' + name + ')) {
                    n.classList.add('active');
                }
            });
            
            document.getElementById('pageTitle').textContent = pageTitles[name]  name;
            
            if (name === 'dashboard') renderDashboard();
            if (name === 'products') renderProducts();
            if (name === 'invoices') renderInvoices();
            if (name === 'customers') renderCustomers();
            if (name === 'suppliers') renderSuppliers();
            if (name === 'expenses') renderExpenses();
            if (name === 'categories') renderCategories();
            if (name === 'settings') renderSettings();
            if (name === 'sale') initSaleForm();
            if (name === 'purchase') initPurchForm();
        }

         ===================== لوحة التحكم الرسومية والمؤشرات =====================
        function renderDashboard() {
            const today = new Date().toISOString().split('T')[0];
            const thisMonth = today.slice(0,7);
            
            const sales = db.invoices.filter(i = i.type === 'sale');
            const todaySales = sales.filter(i = i.date === today);
            const monthSales = sales.filter(i = i.date.startsWith(thisMonth));
            
            const totalRevenue = monthSales.reduce((s,i) = s + (i.netTotal0), 0);
            const totalProfit = monthSales.reduce((s,i) = s + ((i.netTotal0) - (i.costTotal0)), 0);
            const lowStock = db.products.filter(p = p.qty = (p.minStock  db.settings.minStock));

            document.getElementById('dashStats').innerHTML = `
                div class=stat-card
                    div class=stat-icon💰div
                    div class=stat-labelمبيعات الشهر الحاليdiv
                    div class=stat-value${fmt(totalRevenue)}div
                    div class=stat-subريال سعودي صافيdiv
                div
                div class=stat-card
                    div class=stat-icon📈div
                    div class=stat-labelالعوائد الربحية (تقريبي)div
                    div class=stat-value style=colorvar(--success)${fmt(totalProfit)}div
                    div class=stat-subبناءً على فروقات التكلفةdiv
                div
                div class=stat-card
                    div class=stat-icon🧾div
                    div class=stat-labelمبيعات اليومdiv
                    div class=stat-value${fmt(todaySales.reduce((s,i)=s+(i.netTotal0),0))}div
                    div class=stat-sub${todaySales.length} عمليات فواتير منفذةdiv
                div
                div class=stat-card
                    div class=stat-icon⚠️div
                    div class=stat-labelالأصناف تحت حد الطلبdiv
                    div class=stat-value style=colorvar(--danger)${lowStock.length}div
                    div class=stat-subتتطلب إعادة مشتريات وتوريدdiv
                div
            `;

             رسم مخطط المبيعات البسيط لآخر 7 أيام
            const days7 = [];
            for (let i = 6; i = 0; i--) {
                const d = new Date();
                d.setDate(d.getDate() - i);
                const ds = d.toISOString().split('T')[0];
                const dayTotal = sales.filter(s = s.date === ds).reduce((s,i) = s + (i.netTotal0), 0);
                days7.push({
                    label d.toLocaleDateString('ar-SA', {weekday'short'}),
                    val dayTotal
                });
            }
            
            const maxV = Math.max(...days7.map(d = d.val), 1);
            document.getElementById('salesChart').innerHTML = days7.map(d = `
                div class=chart-bar-wrap
                    div class=chart-val${d.val  0  fmt(d.val)  ''}div
                    div class=chart-bar income style=height${Math.round((d.valmaxV)120)+4}pxdiv
                    div class=chart-label${d.label}div
                div
            `).join('');

             تنبيهات مخزون منخفض
            const sa = document.getElementById('stockAlerts');
            if (lowStock.length === 0) {
                sa.innerHTML = 'div style=text-aligncenter;colorvar(--success);padding20px;font-size13px✅ مستويات المخزون الحالي ممتازة وآمنة تماماًdiv';
            } else {
                sa.innerHTML = lowStock.map(p = `
                    div class=alert ${p.qty === 0  'alert-danger'  'alert-warning'} style=margin-bottom8px;padding8px 12px;font-size12px
                        ${p.qty === 0  '🚫'  '⚠️'} strong${p.name}strong — الكمية المتوفرة ${p.qty} وحدة فقط.
                    div
                `).join('');
            }

             تحديث الشارات في الأعلى
            const badge = document.getElementById('alertBadge');
            if (lowStock.length  0) {
                badge.style.display = '';
                badge.textContent = '⚠️ ' + lowStock.length + ' تنبيه مخزون';
            } else {
                badge.style.display = 'none';
            }

             جدول آخر مبيعات منفذة
            const lastSales = [...sales].sort((a,b) = b.date.localeCompare(a.date)).slice(0,5);
            document.getElementById('lastSalesTable').innerHTML = `
                theadtrthرقم الفاتورةththالتاريخththالعميلththالصافيthtrthead
                tbody${lastSales.length  lastSales.map(i=`trtdb${i.num}btdtd${i.date}tdtd${i.customerName'-'}tdtd style=colorvar(--success);font-weight700${fmt(i.netTotal)} ر.سtdtr`).join('')  'trtd colspan=4 class=empty-stateلا توجد عمليات مبيعات مسجلة حتى الآنtdtr'}tbody
            `;

             السلع الأكثر مبيعاً
            const salesCount = {};
            sales.forEach(inv = inv.items.forEach(it = {
                salesCount[it.productId] = (salesCount[it.productId]0) + it.qty;
            }));
            const top5 = Object.entries(salesCount).sort((a,b)=b[1]-a[1]).slice(0,5);
            document.getElementById('topProductsTable').innerHTML = `
                theadtrthاسم الكتاب  الصنفththالوحدات المباعةthtrthead
                tbody${top5.length  top5.map(([pid,cnt])={const p=db.products.find(x=x.id===pid); return `trtd${pp.namepid}tdtdb${cnt} وحدةbtdtr`;}).join('')  'trtd colspan=2 class=empty-stateلا توجد مبيعات لإدراج إحصائيةtdtr'}tbody
            `;
        }

         ===================== المساعدين الماليين والأدوات العامة =====================
        function fmt(n) { return parseFloat(n0).toFixed(2).replace(B(=(d{3})+(!d))g,','); }
        function getTodayDate() { return new Date().toISOString().split('T')[0]; }
        
        function toggleNotif() {
            const popup = document.getElementById('notifPopup');
            const lowStock = db.products.filter(p = p.qty = (p.minStock  db.settings.minStock));
            popup.innerHTML = `div style=padding10px 16px;font-weight700;font-size13px;border-bottom1px solid var(--border);colorvar(--primary)🔔 قائمة الإشعارات الحرجة للمستودعdiv` + 
                (lowStock.length === 0  'div class=notif-item✅ المخزون سليم بالكاملdiv'  lowStock.map(p=`div class=notif-item ${p.qty===0'danger''warning'}${p.qty===0'🚫 نفد تماماً''⚠️ منخفض جداً'} b${p.name}b (المتبقي ${p.qty})div`).join(''));
            popup.classList.toggle('show');
        }

        document.addEventListener('click', e = {
            if (!e.target.closest('#notifPopup') && !e.target.closest('#alertBadge')) {
                document.getElementById('notifPopup').classList.remove('show');
            }
        });

         ===================== دورة حياة فواتير المبيعات وزاوية النقاط =====================
        let saleItems = [];
        function initSaleForm() {
            document.getElementById('saleCustomer').innerHTML = db.customers.map(c=`option value=${c.id}${c.name}option`).join('');
            document.getElementById('saleItemProd').innerHTML = 'option value=-- اختر الكتاب أو المادة للبيع --option' + db.products.filter(p=p.qty0).map(p=`option value=${p.id}${p.name} (المتاح ${p.qty})option`).join('');
            document.getElementById('saleDate').value = getTodayDate();
            document.getElementById('saleInvNum').textContent = 'رقم المستند المقترح ' + getNextInvNum('S');
            document.getElementById('saleVat').value = db.settings.vatPct  15;
            saleItems = [];
            renderSaleItems();
        }

        function fillSaleItem() {
            const pid = document.getElementById('saleItemProd').value;
            const p = db.products.find(x = x.id === pid);
            if (p) {
                document.getElementById('saleItemPrice').value = p.price  0;
                calcSaleItemTotal();
            }
        }

        function calcSaleItemTotal() {
            const q = parseFloat(document.getElementById('saleItemQty').value)0;
            const pr = parseFloat(document.getElementById('saleItemPrice').value)0;
            document.getElementById('saleItemTotal').value = fmt(q  pr);
        }

        function addSaleItem() {
            const pid = document.getElementById('saleItemProd').value;
            const p = db.products.find(x = x.id === pid);
            if (!p) return alert('الرجاء تحديد صنف صحيح للعملية');
            
            const qty = parseInt(document.getElementById('saleItemQty').value)0;
            if (qty = 0) return alert('الكمية المباعة يجب أن تزيد عن صفر');
            if (qty  p.qty) return alert(`المخزون لا يكفي! المتاح حالياً من [${p.name}] هو ${p.qty} فقط.`);
            
            const price = parseFloat(document.getElementById('saleItemPrice').value)0;
            const existing = saleItems.find(x = x.productId === pid);
            
            if (existing) {
                if (existing.qty + qty  p.qty) return alert('إجمالي الكمية المضافة يتجاوز سقف المستودع المتاح');
                existing.qty += qty;
                existing.total = existing.qty  existing.price;
            } else {
                saleItems.push({
                    productId pid,
                    name p.name,
                    qty,
                    price,
                    cost p.cost  0,
                    total qty  price
                });
            }
            renderSaleItems();
        }

        function removeSaleItem(idx) {
            saleItems.splice(idx, 1);
            renderSaleItems();
        }

        function renderSaleItems() {
            const list = document.getElementById('saleItemsList');
            list.innerHTML = saleItems.map((it, i) = `
                div class=invoice-row
                    span${i+1}spanspan${it.name}spanspan${it.qty}span
                    span${fmt(it.price)}spanspan style=font-weight700${fmt(it.total)}span
                    button class=btn btn-danger btn-sm onclick=removeSaleItem(${i})✕button
                div
            `).join('')  'div style=padding16px;text-aligncenter;colorvar(--text3);font-size13pxلم تقم بإضافة عناصر للفاتورة الحالية بعدdiv';
            calcSaleTotals();
        }

        function calcSaleTotals() {
            const subtotal = saleItems.reduce((s, it) = s + it.total, 0);
            const disc = parseFloat(document.getElementById('saleDiscount').value)0;
            const vat = parseFloat(document.getElementById('saleVat').value)0;
            
            const discAmt = subtotal  disc  100;
            const afterDisc = subtotal - discAmt;
            const vatAmt = afterDisc  vat  100;
            const net = afterDisc + vatAmt;

            document.getElementById('saleTotals').innerHTML = `
                divspan class=labelالإجمالي قبل الخصمspanspan class=value${fmt(subtotal)} ر.سspandiv
                ${disc  0  `divspan class=labelالخصم الممنوح (${disc}%)spanspan class=value style=colorvar(--danger)- ${fmt(discAmt)} ر.سspandiv`  ''}
                ${vat  0  `divspan class=labelضريبة القيمة المضافة (${vat}%)spanspan class=value${fmt(vatAmt)} ر.سspandiv`  ''}
                divspan class=label style=font-weight800;colorvar(--primary)الصافي الإجمالي المطلوبspanspan class=value style=colorvar(--primary);font-size18px${fmt(net)} ر.سspandiv
            `;
            return { subtotal, discAmt, vatAmt, net };
        }

        function saveSaleInvoice() {
            if (saleItems.length === 0) return alert('لا يمكن حفظ الفاتورة بدون بنود وعناصر مضافة');
            const custId = document.getElementById('saleCustomer').value  'cust0';
            const cust = db.customers.find(c = c.id === custId);
            const totals = calcSaleTotals();
            const invNum = getNextInvNum('S');

            const inv = {
                id genId('SINV'),
                type 'sale',
                num invNum,
                date document.getElementById('saleDate').value,
                customerId custId,
                customerName cust  cust.name  'عميل نقدي',
                payType document.getElementById('salePayType').value,
                notes document.getElementById('saleNotes').value,
                items JSON.parse(JSON.stringify(saleItems)),
                subtotal totals.subtotal,
                discAmt totals.discAmt,
                vatAmt totals.vatAmt,
                netTotal totals.net,
                costTotal saleItems.reduce((s, it) = s + (it.cost  it.qty), 0),
                discount parseFloat(document.getElementById('saleDiscount').value)0,
                vat parseFloat(document.getElementById('saleVat').value)0
            };

             ترحيل المخزون الفوري والخصم
            saleItems.forEach(it = {
                const p = db.products.find(x = x.id === it.productId);
                if (p) p.qty -= it.qty;
            });

            db.invoices.push(inv);
            saveDB();
            alert('✅ تم ترحيل وحفظ فاتورة المبيعات بنجاح برقم ' + invNum);
            clearSaleForm();
            showPage('dashboard');
        }

        function clearSaleForm() {
            saleItems = [];
            document.getElementById('saleDiscount').value = '0';
            document.getElementById('saleNotes').value = '';
            document.getElementById('saleItemQty').value = '1';
            document.getElementById('saleItemPrice').value = '';
            document.getElementById('saleItemTotal').value = '';
            initSaleForm();
        }

        function previewSaleInvoice() {
            if (saleItems.length === 0) return alert('أضف عناصر أولاً للمعاينة والطباعة');
            const totals = calcSaleTotals();
            const custId = document.getElementById('saleCustomer').value  'cust0';
            const cust = db.customers.find(c = c.id === custId);
            const s = db.settings;
            
            const html = buildInvoiceHTML({
                type 'sale',
                num getNextInvNum('S'),
                date document.getElementById('saleDate').value,
                personName cust  cust.name  'عميل نقدي',
                payType document.getElementById('salePayType').value,
                notes document.getElementById('saleNotes').value,
                items saleItems,
                totals,
                s
            });
            
            const w = window.open('', '_blank');
            w.document.write(html);
            w.document.close();
        }

