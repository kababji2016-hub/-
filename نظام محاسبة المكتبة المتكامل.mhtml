body

    !-- تسجيل الدخول --
    div id=loginScreen
        div class=login-box
            div class=login-logo📚div
            h1نظام محاسبة المكتبةh1
            pالرجاء تسجيل الدخول للمتابعةp
            div class=login-field
                labelاسم المستخدمlabel
                input type=text id=loginUser value=admin placeholder=admin 
            div
            div class=login-field
                labelكلمة المرورlabel
                input type=password id=loginPass value=1234 placeholder=•••••••• onkeydown=if(event.key==='Enter')doLogin() 
            div
            button class=login-btn onclick=doLogin()🔐 دخولbutton
            div class=login-error id=loginErr❌ اسم المستخدم أو كلمة المرور غير صحيحةdiv
            div class=login-hintالمستخدم الافتراضي admin  كلمة المرور 1234div
        div
    div

    !-- التطبيق الرئيسي --
    div id=app
        !-- SIDEBAR --
        nav class=sidebar
            div class=sidebar-header
                div class=sidebar-logo📚div
                div class=sidebar-titleنظام المكتبة المتكاملdiv
                div class=sidebar-store id=storeNameمكتبة النور والشرقdiv
            div
            div class=sidebar-nav
                div class=nav-sectionالرئيسيةdiv
                div class=nav-item active onclick=showPage('dashboard')span class=icon🏠span لوحة التحكمdiv
                div class=nav-sectionالمعاملاتdiv
                div class=nav-item onclick=showPage('sale')span class=icon🧾span فاتورة المبيعاتdiv
                div class=nav-item onclick=showPage('purchase')span class=icon📦span فاتورة المشترياتdiv
                div class=nav-item onclick=showPage('invoices')span class=icon📋span سجل الفواتيرdiv
                div class=nav-sectionالمخزونdiv
                div class=nav-item onclick=showPage('products')span class=icon📗span الأصناف والكتبdiv
                div class=nav-item onclick=showPage('categories')span class=icon🗂️span الفئاتdiv
                div class=nav-sectionالأطرافdiv
                div class=nav-item onclick=showPage('customers')span class=icon👥span إدارة العملاءdiv
                div class=nav-item onclick=showPage('suppliers')span class=icon🏭span إدارة الموردينdiv
                div class=nav-sectionالماليةdiv
                div class=nav-item onclick=showPage('expenses')span class=icon💸span المصروفاتdiv
                div class=nav-sectionالنظامdiv
                div class=nav-item onclick=showPage('settings')span class=icon⚙️span الإعدادات العامّةdiv
                div class=nav-item onclick=backupData()span class=icon💾span نسخة احتياطيةdiv
                div class=nav-item onclick=importBackup()span class=icon📥span استعادة البياناتdiv
            div
            div class=sidebar-footerالإصدار 2.0  نظام آمنdiv
        nav

        div class=main
            !-- الشريط العلوي --
            div class=topbar
                div class=topbar-title id=pageTitleلوحة التحكمdiv
                div class=topbar-right
                    span class=topbar-badge onclick=toggleNotif() id=alertBadge style=displaynone⚠️ تنبيهاتspan
                    span class=topbar-user id=topbarUser👤 adminspan
                    button class=logout-btn onclick=doLogout()تسجيل الخروجbutton
                div
            div

